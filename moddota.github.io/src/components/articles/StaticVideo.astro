---
interface Props {
  path: string;
  controls?: boolean;
}

const { path, controls = false } = Astro.props;
const base = import.meta.env.BASE_URL;
const videoSrc = path.startsWith('/') ? `${base}${path.slice(1)}` : path;
---

<video
  src={videoSrc}
  autoplay
  muted
  loop
  controls={controls}
  style="width: 100%; height: 100%; margin-bottom: 1rem;"
></video>
