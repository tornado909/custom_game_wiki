---
import '../styles/global.css';
import { ArticleEditor } from '../components/articles/ArticleEditor';

const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>New Article - ModDota</title>
    <link rel="icon" href={`${base}images/favicon.ico`} />
  </head>
  <body style="height: 100%; display: flex; flex-direction: column;">
    <nav style="background-color: var(--color-navbar); border-bottom: 1px solid var(--color-border); box-shadow: 0 0 4px var(--color-navbar-shadow);">
      <div style="display: flex; align-items: center; max-width: 1400px; margin: 0 auto; padding: 0 1rem; height: 56px;">
        <a href={base} style="display: flex; align-items: center; gap: 8px; font-weight: bold; color: var(--color-text); text-decoration: none;">
          <img src={`${base}images/logo.svg`} alt="ModDota" width="36" height="32" onerror="this.style.display='none'" />
          <span>ModDota</span>
        </a>
        <div style="margin-left: auto; display: flex; gap: 1rem;">
          <a href={base} style="padding: 8px 16px; font-weight: 600; color: var(--color-text-dim);">Articles</a>
          <a href={`${base}api/vscripts`} style="padding: 8px 16px; font-weight: 600; color: var(--color-text-dim);">API</a>
        </div>
      </div>
    </nav>
    <div style="flex: 1; display: flex; flex-direction: column; min-height: 0;">
      <ArticleEditor client:load />
    </div>

    <script>
      const theme = localStorage.getItem('theme');
      if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.setAttribute('data-theme', 'dark');
      }
    </script>
  </body>
</html>
