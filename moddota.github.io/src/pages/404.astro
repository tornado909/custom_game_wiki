---
// GitHub Pages SPA fallback.
//
// GitHub Pages serves this file (as `404.html`) whenever a requested path has
// no matching static file. For client-side routes under `/api/<section>/…` —
// e.g. `/api/vscripts/CDOTA_BaseNPC` or `/api/changelog/6761` — we rewrite the
// URL to the closest built section index page (`/api/<section>/`) while
// stashing the original sub-path in `sessionStorage`. `ApiLayout.astro` reads
// that value on load, restores the URL with `history.replaceState`, and lets
// the React islands render the correct scope from `window.location.pathname`.
//
// For non-API paths we fall through to a plain 404 message.
import '../styles/global.css';

const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Not Found - ModDota</title>
    <base href={base} />
    <link rel="icon" href={`${base}images/favicon.ico`} />
    <script is:inline define:vars={{ base }}>
      (function () {
        var l = window.location;
        var pathname = l.pathname;
        // Strip the site base prefix so we can reason about the app-relative path.
        var rel = pathname.indexOf(base) === 0 ? pathname.slice(base.length) : pathname.replace(/^\//, '');
        rel = rel.replace(/^\//, '').replace(/\/+$/, '');

        var segments = rel.split('/');
        if (segments.length < 3 || segments[0] !== 'api') return;

        // Sections may be one segment (`vscripts`) or two (`panorama/api`).
        // Try the two-segment form first, then fall back to one segment.
        var knownSections = [
          'modifiers',
          'abilities',
          'localization',
          'search',
        ];

        var section = null;
        var restStart = 0;
        var twoSeg = segments.length >= 4 ? segments[1] + '/' + segments[2] : null;
        if (twoSeg && knownSections.indexOf(twoSeg) !== -1) {
          section = twoSeg;
          restStart = 3;
        } else if (knownSections.indexOf(segments[1]) !== -1) {
          section = segments[1];
          restStart = 2;
        }
        if (!section) return;

        var rest = segments.slice(restStart).join('/');
        if (!rest) return;

        try {
          sessionStorage.setItem('__spa_redirect', 'api/' + section + '/' + rest);
        } catch (e) {}

        var target = l.origin + base + 'api/' + section + '/' + l.search + l.hash;
        l.replace(target);
      })();
    </script>
  </head>
  <body>
    <div style="padding: 40px; font-family: system-ui, sans-serif; text-align: center;">
      <h1>404 — Not Found</h1>
      <p>
        <a href={base}>Return to home</a>
      </p>
    </div>
  </body>
</html>
