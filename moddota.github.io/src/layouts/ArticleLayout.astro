---
import '../styles/global.css';
import ArticleSidebar from '../components/articles/ArticleSidebar.astro';

interface Props {
  title: string;
  author?: string;
  steamId?: string;
  date?: Date;
  outdated?: boolean;
}

const { title, author, steamId, date, outdated } = Astro.props;
const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} - ModDota</title>
    <link rel="icon" href={`${base}images/favicon.ico`} />
    <script is:inline>
      (function() {
        var theme = localStorage.getItem('theme');
        if (theme === 'dark' || (theme !== 'light' && !theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.setAttribute('data-theme', 'dark');
        }
      })();
    </script>
  </head>
  <body>
    <nav class="article-navbar">
      <div class="article-navbar-inner">
        <a href={base} class="brand-link">
          <img src={`${base}images/logo.svg`} alt="ModDota" width="36" height="32" />
          <span>ModDota</span>
        </a>
        <div class="nav-links">
          <a href={`${base}api/vscripts`}>API</a>
          <a href={`${base}new-article`}>New Article</a>
        </div>
        <button id="theme-toggle" class="theme-toggle-pill" aria-label="Toggle dark mode">
          <span class="theme-toggle-knob"></span>
        </button>
        <button class="burger-btn" id="article-burger" aria-label="Toggle menu">☰</button>
      </div>
      <div class="mobile-menu" id="article-mobile-menu" style="display:none;">
        <div class="mobile-menu-links">
          <a href={base}>Home</a>
          <a href={`${base}api/vscripts`}>API</a>
          <a href={`${base}new-article`}>New Article</a>
        </div>
        <div class="mobile-sidebar">
          <ArticleSidebar currentPath={currentPath} />
        </div>
      </div>
    </nav>

    <div class="article-layout">
      <aside class="article-sidebar" id="article-sidebar">
        <ArticleSidebar currentPath={currentPath} />
      </aside>
      <main class="article-content">
        <article class="article-body">
          <h1>{title}</h1>
          {outdated && (
            <div class="outdated-banner">
              This article is outdated. The information here may no longer be accurate or relevant.
            </div>
          )}
          {author && (
            <div class="article-meta">
              By <strong>{author}</strong>
              {date && <span> &middot; {date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>}
            </div>
          )}
          <slot />
        </article>
      </main>
    </div>

    <script is:inline>
      const burger = document.getElementById('article-burger');
      const mobileMenu = document.getElementById('article-mobile-menu');
      burger?.addEventListener('click', () => {
        const open = mobileMenu?.style.display !== 'none';
        if (mobileMenu) mobileMenu.style.display = open ? 'none' : 'flex';
        if (burger) burger.textContent = open ? '☰' : '✕';
      });

      // Theme toggle
      const themeBtn = document.getElementById('theme-toggle');
      var knob = themeBtn?.querySelector('.theme-toggle-knob');
      function updateThemePill() {
        var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
        if (themeBtn) themeBtn.style.background = isDark ? '#101010' : '#c0c0c0';
        if (knob) {
          knob.style.left = isDark ? '26px' : '2px';
          knob.style.background = isDark ? '#606060' : '#ffffff';
          knob.textContent = isDark ? '\uD83C\uDF1C' : '\uD83C\uDF1E';
        }
      }
      updateThemePill();
      themeBtn?.addEventListener('click', function() {
        var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
        if (isDark) {
          document.documentElement.removeAttribute('data-theme');
          localStorage.setItem('theme', 'light');
        } else {
          document.documentElement.setAttribute('data-theme', 'dark');
          localStorage.setItem('theme', 'dark');
        }
        updateThemePill();
      });
    </script>

    <style>
      .article-navbar {
        background-color: var(--color-navbar);
        border-bottom: 1px solid var(--color-border);
        box-shadow: 0 0 4px var(--color-navbar-shadow);
        position: sticky;
        top: 0;
        z-index: 100;
      }

      .theme-toggle-pill {
        background: #c0c0c0;
        border: none;
        border-radius: 12px;
        width: 48px;
        height: 24px;
        cursor: pointer;
        position: relative;
        transition: background 0.2s;
        margin-left: 8px;
        flex-shrink: 0;
      }
      .theme-toggle-knob {
        position: absolute;
        top: 2px;
        left: 2px;
        width: 20px;
        height: 20px;
        border-radius: 50%;
        background: #ffffff;
        transition: left 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
      }

      .article-navbar-inner {
        display: flex;
        align-items: center;
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 1rem;
        height: 56px;
      }

      .brand-link {
        display: flex;
        align-items: center;
        gap: 8px;
        font-weight: bold;
        color: var(--color-text);
        text-decoration: none;
      }

      .brand-link img {
        height: 32px;
      }

      .nav-links {
        display: flex;
        gap: 1rem;
        margin-left: auto;
      }

      .nav-links a {
        padding: 8px 16px;
        font-weight: 600;
        color: var(--color-text-dim);
      }

      .nav-links a:hover {
        color: var(--color-highlight);
        text-decoration: none;
      }

      .burger-btn {
        display: none;
        background: none;
        border: none;
        font-size: 22px;
        cursor: pointer;
        color: var(--color-text);
        margin-left: auto;
        padding: 8px;
      }

      .mobile-menu {
        flex-direction: column;
        border-top: 1px solid var(--color-border);
        padding: 0;
        max-height: calc(100vh - 56px);
        overflow-y: auto;
      }

      .mobile-menu-links {
        display: flex;
        flex-direction: column;
        border-bottom: 1px solid var(--color-border);
        padding: 8px 0;
      }

      .mobile-menu-links a {
        padding: 10px 20px;
        color: var(--color-text);
        font-weight: 600;
      }

      .mobile-sidebar {
        padding: 8px 12px 16px;
      }

      @media (max-width: 768px) {
        .nav-links {
          display: none;
        }
        .burger-btn {
          display: block;
        }
      }

      .article-layout {
        display: flex;
        max-width: 1400px;
        margin: 0 auto;
        min-height: calc(100vh - 56px);
      }

      .article-sidebar {
        width: 280px;
        padding: 1rem;
        border-right: 1px solid var(--color-border);
        overflow-y: auto;
        position: sticky;
        top: 56px;
        height: calc(100vh - 56px);
        flex-shrink: 0;
      }

      .article-content {
        flex: 1;
        min-width: 0;
        padding: 1.5rem 2rem;
      }

      .article-body {
        max-width: 800px;
        line-height: 1.75;
        font-size: 16px;
      }

      .article-body h1 {
        font-size: 2rem;
        margin-bottom: 0.5rem;
        border-bottom: 1px solid var(--color-border);
        padding-bottom: 0.5rem;
        line-height: 1.3;
      }

      .outdated-banner {
        background: #fff3cd;
        border: 1px solid #ffc107;
        border-radius: 6px;
        padding: 12px 16px;
        margin-bottom: 1rem;
        color: #856404;
        font-weight: 500;
        font-size: 0.95rem;
        line-height: 1.5;
      }

      :global([data-theme='dark']) .outdated-banner {
        background: #332b00;
        border-color: #665500;
        color: #ffd666;
      }

      .article-meta {
        color: var(--color-text-dim);
        margin-bottom: 1.5rem;
        font-size: 0.9rem;
      }

      .article-body :global(h2) {
        font-size: 1.5rem;
        margin-top: 2rem;
        margin-bottom: 0.75rem;
        border-bottom: 1px solid var(--color-border);
        padding-bottom: 0.3rem;
        line-height: 1.3;
      }

      .article-body :global(h3) {
        font-size: 1.25rem;
        margin-top: 1.5rem;
        margin-bottom: 0.5rem;
        line-height: 1.3;
      }

      .article-body :global(h4) {
        font-size: 1.1rem;
        margin-top: 1.25rem;
        margin-bottom: 0.5rem;
      }

      .article-body :global(p) {
        margin-bottom: 1rem;
      }

      .article-body :global(ul),
      .article-body :global(ol) {
        margin-bottom: 1rem;
        padding-left: 2rem;
      }

      .article-body :global(li) {
        margin-bottom: 0.35rem;
      }

      .article-body :global(li > p) {
        margin-bottom: 0.35rem;
      }

      .article-body :global(img) {
        max-width: 100%;
        height: auto;
        border-radius: 4px;
      }

      .article-body :global(a) {
        color: var(--color-highlight);
        text-decoration: none;
      }
      .article-body :global(a:hover) {
        text-decoration: underline;
      }

      .article-body :global(code:not(pre code)) {
        background: var(--color-sidebar);
        padding: 2px 6px;
        border-radius: 4px;
        font-size: 0.85em;
        border: 1px solid var(--color-border);
      }

      .article-body :global(pre) {
        background: var(--color-content-bg);
        border: 1px solid var(--color-border);
        border-radius: 6px;
        padding: 1rem;
        overflow-x: auto;
        margin: 1rem 0;
        line-height: 1.5;
      }

      .article-body :global(pre code) {
        background: none;
        border: none;
        padding: 0;
        font-size: 0.85em;
      }

      .article-body :global(table) {
        border-collapse: collapse;
        width: 100%;
        margin: 1rem 0;
      }

      .article-body :global(th),
      .article-body :global(td) {
        border: 1px solid var(--color-border);
        padding: 8px 12px;
        text-align: left;
      }

      .article-body :global(th) {
        background: var(--color-sidebar);
        font-weight: 600;
      }

      .article-body :global(blockquote) {
        border-left: 4px solid var(--color-highlight);
        margin: 1rem 0;
        padding: 0.5rem 1rem;
        color: var(--color-text-dim);
        background: var(--color-sidebar);
        border-radius: 0 4px 4px 0;
      }

      .article-body :global(hr) {
        border: none;
        border-top: 1px solid var(--color-border);
        margin: 2rem 0;
      }

      .article-body :global(iframe) {
        border-radius: 6px;
      }

      @media (max-width: 768px) {
        .article-sidebar {
          display: none;
        }
        .article-content {
          padding: 1rem;
        }
      }
    </style>
  </body>
</html>
