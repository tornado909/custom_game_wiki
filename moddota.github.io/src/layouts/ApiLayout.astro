---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
}

const { title } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} - Map Wiki</title>
    <base href={base} />
    <link rel="icon" href={`${base}images/favicon.ico`} />
    {/* Enables instant client-side navigation between API tabs (no full reload). */}
    <ClientRouter />
    <script is:inline>
      // Theme initialization - must run before body renders to prevent flash.
      function applyTheme() {
        var theme = localStorage.getItem('theme');
        if (theme === 'dark' || (theme !== 'light' && !theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.setAttribute('data-theme', 'dark');
        } else {
          document.documentElement.removeAttribute('data-theme');
        }
      }
      applyTheme();
      // Re-apply before paint on client-side (View Transitions) navigations so the
      // theme never flashes. The listener is registered once and persists on document.
      document.addEventListener('astro:after-swap', applyTheme);
    </script>
    <script is:inline define:vars={{ base }}>
      // SPA fallback decoder — must run before React islands hydrate so that
      // components reading `window.location.pathname` see the original URL.
      // Pairs with `src/pages/404.astro`, which stashes the original path in
      // sessionStorage before redirecting to the section's index page.
      (function () {
        try {
          var stashed = sessionStorage.getItem('__spa_redirect');
          if (!stashed) return;
          sessionStorage.removeItem('__spa_redirect');
          var target = base + stashed;
          // Only restore if we actually landed on an ancestor of the stashed path.
          if (window.location.pathname.indexOf(base) !== 0) return;
          if (target.indexOf(window.location.pathname.replace(/\/$/, '')) !== 0) return;
          window.history.replaceState({}, '', target + window.location.search + window.location.hash);
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <div id="api-root" style="display:flex;flex-direction:column;height:100%;">
      <slot />
    </div>
  </body>
</html>
