{
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "lint": "npm run lint:prettier",
    "lint:prettier": "prettier --check .",
    "fix:prettier": "prettier --write .",
    "prebuild": "node scripts/copy-data.cjs",
    "predev": "node scripts/predev.cjs"
  },
  "prettier": {
    "printWidth": 120,
    "trailingComma": "all",
    "overrides": [
      {
        "files": "*.md",
        "options": {
          "parser": "mdx",
          "printWidth": 100,
          "tabWidth": 2,
          "singleQuote": true
        }
      }
    ]
  },
  "dependencies": {
    "@astrojs/mdx": "^4.0.0",
    "@astrojs/react": "^4.0.0",
    "@moddota/dota-data": "^0.45.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/react-virtualized": "^9.21.10",
    "astro": "^5.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-virtualized": "^9.22.2",
    "tailwindcss": "^4.0.0",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "prettier": "^2.8.8",
    "typescript": "^5.0.4"
  },
  "browserslist": [
    "last 1 chrome version",
    "last 1 firefox version",
    "last 1 safari version"
  ]
}
